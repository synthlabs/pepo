        "@sveltejs/kit": "^2.64.0",
        "@sveltejs/vite-plugin-svelte": "^7.1.2",
        "@tailwindcss/postcss": "^4.3.0",
        "@tailwindcss/vite": "^4.3.0",
        "@tauri-apps/cli": "^2.11.2",
        "@types/node": "^25.9.3",
        "bits-ui": "2.18.0",
        "clsx": "^2.1.1",
        "eslint": "^10.4.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-svelte": "^3.19.0",
